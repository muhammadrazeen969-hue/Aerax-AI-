# AeraX AI — API Server Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Required ────────────────────────────────────────────────────────────────

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Port the server listens on (default 8080)
PORT=8080

# ─── Optional ────────────────────────────────────────────────────────────────

# Session secret for signed cookies (generate a long random string)
SESSION_SECRET=change_me_to_a_long_random_string

# Node environment (development | production)
NODE_ENV=development

# ─── Replit-only (do NOT set these outside Replit) ───────────────────────────
# AI_INTEGRATIONS_OPENAI_API_KEY=   ← set automatically by Replit AI Integration
# AI_INTEGRATIONS_OPENAI_BASE_URL=  ← set automatically by Replit AI Integration
