# AeraX AI — Mobile App Environment Variables
# Copy this file to .env and fill in your values.
# All EXPO_PUBLIC_* vars are bundled into the client — do NOT put secrets here.

# ─── Required ────────────────────────────────────────────────────────────────

# Full domain of your deployed API server (no trailing slash, no protocol)
# Local dev:  EXPO_PUBLIC_DOMAIN=localhost:8080
# Production: EXPO_PUBLIC_DOMAIN=api.yourdomain.com
EXPO_PUBLIC_DOMAIN=localhost:8080

# ─── Build / Deploy ──────────────────────────────────────────────────────────

# Used by scripts/build.js to set absolute asset URLs.
# Set to your production domain before running `pnpm run build`.
# APP_DOMAIN=yourdomain.com

# ─── Replit-only (do NOT set these outside Replit) ───────────────────────────
# REPLIT_EXPO_DEV_DOMAIN=   ← set automatically by Replit
# REPLIT_DEV_DOMAIN=        ← set automatically by Replit
# REPL_ID=                  ← set automatically by Replit
# PORT=                     ← set automatically by Replit
